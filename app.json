{
  "expo": {
    "name": "Meu Guia de Compras",
    "slug": "Meu Guia de Compras",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon-1.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.hero.meuguiadecompras",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
